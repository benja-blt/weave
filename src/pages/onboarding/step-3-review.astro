---
// src/pages/onboarding/step-3-review.astro — Paso 3: review del brief antes de buscar patrones.
// Muestra un resumen de lo cargado en step-1/step-2, deja expandir el prompt libre con más
// detalle (pisa data.prompt si el usuario escribe algo acá) y sumar features opcionales.
// Mismo patrón de guard que step-3-patterns/step-4: localStorage 'weave:onboarding'.
import Onboarding from '../../layouts/Onboarding.astro';
---
<Onboarding
  step={3}
  total={5}
  title="Weave — Paso 3: revisá tu idea"
  heading="Contanos <em>en detalle.</em>"
  sub="Repasá lo que ya nos dijiste y agregá todo el detalle que quieras — cuanto más específico, mejor sale tu web."
>
  <form id="step3review" class="s3r" novalidate>
    <!-- Resumen de lo ya cargado -->
    <div class="o-field" data-motion-el data-motion-order="3">
      <span class="o-label">Tu configuración</span>
      <div class="s3r-summary">
        <div class="s3r-summary__item">
          <span class="s3r-summary__label">Nicho</span>
          <span class="s3r-summary__value" id="summary-niche">—</span>
        </div>
        <div class="s3r-summary__item">
          <span class="s3r-summary__label">Negocio</span>
          <span class="s3r-summary__value" id="summary-name">—</span>
        </div>
        <div class="s3r-summary__item">
          <span class="s3r-summary__label">Fotos subidas</span>
          <span class="s3r-summary__value" id="summary-photos">0</span>
        </div>
      </div>
    </div>

    <!-- Prompt detallado -->
    <div class="o-field" data-motion-el data-motion-order="4">
      <label class="o-label" for="detailed-prompt">Tu idea para la web <span class="opt">(cuanto más detalle, mejor)</span></label>
      <textarea class="o-textarea" id="detailed-prompt" name="detailedPrompt" rows="8"
        placeholder={"Ejemplo:\n· Secciones: hero, galería, testimonios, contacto, ubicación\n· Estilo: moderno, elegante, rústico, playero...\n· Colores: colores específicos o referencias\n· Fotos: dónde van (hero, galería, fondos)\n· Textos: qué decir en cada sección\n· Llamadas a acción: reservar, contactar, comprar...\n· Referencias: webs que te gusten\n· Cualquier detalle importante"}></textarea>
    </div>

    <!-- Features opcionales -->
    <div class="o-field" data-motion-el data-motion-order="5">
      <span class="o-label">¿Qué más querés? <span class="opt">(opcional)</span></span>
      <span class="o-hint">Seleccioná los elementos que necesitás.</span>
      <div class="s3r-features">
        <label class="s3r-feature"><input type="checkbox" name="feature" value="contact-form" /><span>Formulario de contacto</span></label>
        <label class="s3r-feature"><input type="checkbox" name="feature" value="gallery" /><span>Galería de fotos</span></label>
        <label class="s3r-feature"><input type="checkbox" name="feature" value="testimonials" /><span>Sección de testimonios</span></label>
        <label class="s3r-feature"><input type="checkbox" name="feature" value="map" /><span>Mapa de ubicación</span></label>
        <label class="s3r-feature"><input type="checkbox" name="feature" value="blog" /><span>Blog / Noticias</span></label>
        <label class="s3r-feature"><input type="checkbox" name="feature" value="pricing" /><span>Tabla de precios</span></label>
      </div>
    </div>

    <!-- Datos reales para tu web (opcional) -->
    <div class="o-field" data-motion-el data-motion-order="6">
      <span class="o-label">Datos reales para tu web <span class="opt">(opcional)</span></span>
      <span class="o-hint">Si los cargás, tu web los muestra de verdad. Si no, quedan notas editables.</span>

      <div class="s3r-paste">
        <label class="s3r-real__lbl" for="rd-paste">Pegá info del negocio y detectamos los datos por vos</label>
        <textarea class="o-textarea" id="rd-paste" rows="6"
          placeholder="Pegá acá info de Google Maps, carta, reseñas, dirección, teléfono u horarios."></textarea>
        <div class="s3r-paste__actions">
          <button type="button" class="btn btn--ghost" id="rd-detect">Detectar datos</button>
          <span class="s3r-paste__status" id="rd-detect-status" aria-live="polite"></span>
        </div>
        <div class="s3r-detected" id="rd-detected" hidden></div>
      </div>

      <div class="s3r-real">
        <div class="s3r-real__row">
          <label class="s3r-real__field">
            <span class="s3r-real__lbl">WhatsApp / teléfono</span>
            <input class="o-input" id="rd-whatsapp" name="whatsapp" type="text" maxlength="40" placeholder="+54 9 11 2345-6789" />
          </label>
          <label class="s3r-real__field">
            <span class="s3r-real__lbl">Dirección</span>
            <input class="o-input" id="rd-address" name="address" type="text" maxlength="120" placeholder="Av. Corrientes 1234, CABA" />
          </label>
        </div>

        <span class="s3r-real__sub">Carta / menú <span class="opt">(hasta 5 ítems, precio opcional)</span></span>
        <div id="rd-menu">
          {[0, 1, 2, 3, 4].map((i) => (
            <div class="s3r-real__row s3r-menu-row">
              <input class="o-input" type="text" data-menu-name maxlength="60" placeholder={`Ítem ${i + 1} — nombre`} />
              <input class="o-input s3r-real__price" type="text" data-menu-price maxlength="20" placeholder="Precio (opcional)" />
            </div>
          ))}
        </div>

        <span class="s3r-real__sub">Testimonios <span class="opt">(hasta 3, nombre opcional)</span></span>
        <div id="rd-testi">
          {[0, 1, 2].map((i) => (
            <div class="s3r-real__row s3r-testi-row">
              <textarea class="o-input s3r-real__quote" data-testi-quote maxlength="600" rows="3" placeholder={`Reseña ${i + 1}`}></textarea>
              <input class="o-input s3r-real__who" type="text" data-testi-who maxlength="40" placeholder="Nombre (opcional)" />
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="o-actions" data-motion-el data-motion-order="7">
      <a class="o-back" href="/onboarding/step-2">← Atrás</a>
      <button class="btn btn--accent btn--lg" type="submit" id="continue">
        Ver mis patrones <span aria-hidden="true">→</span>
      </button>
    </div>
  </form>

  <style is:global>
    /* Campos nuevos de step-3-review — prefijo .s3r, mismo patrón que .s1/.s2. */
    .s3r .o-label .opt { font-family: var(--font-family-body); font-weight: var(--weight-regular); font-size: var(--size-sm); color: var(--muted); }

    .s3r-summary { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); }
    @media (max-width: 620px) { .s3r-summary { grid-template-columns: 1fr; } }
    .s3r-summary__item { padding: var(--space-4); border: 1px solid var(--line); border-radius: var(--radius-card); background: rgba(255, 255, 255, 0.02); }
    .s3r-summary__label { display: block; font-family: var(--font-family-mono); font-size: var(--size-xs); text-transform: uppercase; letter-spacing: var(--tracking-wide); color: var(--muted); margin-bottom: var(--space-2); }
    .s3r-summary__value {
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
      font-size: var(--size-sm); color: var(--ink);
    }

    .s3r-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); }
    @media (max-width: 620px) { .s3r-features { grid-template-columns: 1fr; } }
    .s3r-feature {
      display: flex; align-items: center; gap: var(--space-3); padding: var(--space-4);
      border: 1px solid var(--line); border-radius: var(--radius-card); cursor: pointer;
      background: rgba(255, 255, 255, 0.02); color: var(--muted); font-size: var(--size-sm);
      transition: border-color 200ms ease, background 200ms ease, color 200ms ease;
    }
    .s3r-feature:hover { color: var(--ink); border-color: rgba(255, 255, 255, 0.2); }
    .s3r-feature input { accent-color: var(--accent); width: 18px; height: 18px; flex-shrink: 0; }
    .s3r-feature:has(input:checked) { color: var(--ink); border-color: var(--accent); background: rgba(79, 142, 247, 0.1); }
    .s3r-real { display: flex; flex-direction: column; gap: var(--space-3); margin-top: var(--space-2); }
    .s3r-real__row { display: flex; gap: var(--space-3); flex-wrap: wrap; }
    .s3r-real__field { display: flex; flex-direction: column; gap: var(--space-2); flex: 1 1 200px; }
    .s3r-real__lbl { font-size: var(--size-sm); color: var(--muted); }
    .s3r-real__sub { margin-top: var(--space-3); font-size: var(--size-sm); font-weight: var(--weight-medium); color: var(--ink); }
    .s3r-real__row .o-input { flex: 1 1 200px; }
    .s3r-real__price, .s3r-real__who { flex: 0 1 170px; }
    .s3r-real__row .s3r-real__quote { flex: 1 1 100%; resize: vertical; min-height: 3.4rem; line-height: 1.5; font-family: inherit; }
    @media (max-width: 620px) { .s3r-real__price, .s3r-real__who { flex: 1 1 100%; } }

    /* Campo "pegar info + Detectar datos" */
    .s3r-paste { display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-3); }
    .s3r-paste__actions { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
    .s3r-paste__status { font-size: var(--size-sm); color: var(--muted); }
    .s3r-detected {
      border: 1px solid var(--line); border-radius: var(--radius-card); padding: var(--space-4);
      background: rgba(255, 255, 255, 0.02); font-size: var(--size-sm); color: var(--ink);
    }
    .s3r-detected[hidden] { display: none; }
    .s3r-detected__title { margin: 0 0 var(--space-2); font-weight: var(--weight-semibold); }
    .s3r-detected__list { margin: 0; padding-left: 1.1rem; display: flex; flex-direction: column; gap: 3px; }
    .s3r-detected__note { margin: var(--space-2) 0 0; color: var(--muted); }
  </style>

  <script>
    const KEY = 'weave:onboarding';
    const PKEY = 'weave:onboarding:photos';
    const form = document.getElementById('step3review');

    // ── Detector de datos: parsea un bloque real (Google Maps / carta / reseñas) y devuelve
    // solo lo que reconoce con confianza. No inventa: si algo no aparece, queda vacío.
    function detectInfo(raw) {
      const text = String(raw || '');
      const lines = text.split(/\r?\n/).map((s) => s.trim());
      const lc = (s) => s.toLowerCase().trim();

      const JUNK = new Set([
        'overview', 'menu', 'menú', 'reviews', 'review', 'about', 'directions', 'save', 'nearby',
        'send to phone', 'share', 'dine-in', 'dine in', 'delivery', 'takeout', 'take-out',
        'your maps history', 'add a label', 'suggest an edit', 'write a review', 'like', 'liked',
        'see translation', 'more reviews', 'more', 'popular', 'review summary', 'photos', 'photo',
        'order online', 'call', 'website', 'open now', 'restaurant', 'all', 'from owner', 'sponsored',
      ]);
      const isJunk = (l) => {
        const t = lc(l);
        if (!t) return true;
        if (JUNK.has(t)) return true;
        if (/^see translation/i.test(t)) return true;
        if (/^local guide\b/i.test(t)) return true;
        if (/^\(\d[\d.,]*\)\S*$/.test(t)) return true;
        if (/^\d+\s+(month|year|week|day|hour|minute)s?\s+ago$/i.test(t)) return true;
        if (/^\$[\d.,]+(\s*[–-]\s*\$?[\d.,]+)?(\s*per person)?$/i.test(t)) return true;
        if (/per person/i.test(t)) return true;
        if (/^[★☆*\s·|.]+$/.test(t)) return true;
        return false;
      };

      const REVIEWER_META = /local guide|·\s*\d[\d.,]*\s*photos?\b|\breviews?\s*·/i;
      const ANYMETA = /local guide|·\s*\d[\d.,]*\s*(reviews?|photos?)\b/i;
      const DATE = /\b\d+\s+(month|year|week|day|hour|minute)s?\s+ago\b|\b(today|yesterday)\b/i;
      const STREET = /\b(av\.?|avenida|calle|cl\.|carrera|cra\.?|jr\.?|jirón|ruta|blvd|boulevard|pasaje|psje\.?|diagonal|camino|route|street|st\.|road|rd\.)\b/i;
      const CODE = /\b([A-Z]\d{4}[A-Z]{0,3}|\d{4,5})\b/;

      // Dirección: línea con calle/av… o con código postal + coma (ciudad/provincia).
      let address = '';
      for (const l of lines) {
        if (!l || isJunk(l)) continue;
        if (/\$|per person|reviews?|photos?|opens?\b|closed\b|local guide/i.test(l)) continue;
        const hasStreet = STREET.test(l);
        const hasCode = CODE.test(l) && l.includes(',');
        if ((hasStreet || hasCode) && l.length >= 8 && l.length <= 160) { address = l; break; }
      }

      // Teléfono: solo si parece un número real (7–15 dígitos). Nunca inventa.
      let phone = '';
      for (const l of lines) {
        if (/\$|%|reviews?|photos?|per person|\bago\b|\b[ap]\.?m\.?\b|opens?\b|closed\b/i.test(l)) continue;
        const m = l.match(/\+?\(?\d[\d\s().\-]{6,}\d/);
        if (!m) continue;
        const digits = m[0].replace(/\D/g, '');
        if (digits.length >= 7 && digits.length <= 15) { phone = m[0].replace(/\s{2,}/g, ' ').trim(); break; }
      }

      // Menú: desde el encabezado "Menu"/"Menú" hasta el próximo bloque; ignora navegación.
      const menu = [];
      const startIdx = lines.findIndex((l) => /^men[uú]$/i.test(l.trim()));
      if (startIdx !== -1) {
        const STOP = /^(review summary|reviews?|about|overview|photos?|directions|order online|people also|from the)/i;
        let blanks = 0;
        for (let i = startIdx + 1; i < lines.length && menu.length < 5; i++) {
          const l = lines[i].trim();
          if (!l) { if (++blanks >= 2) break; continue; }
          blanks = 0;
          if (STOP.test(l) || REVIEWER_META.test(l)) break;
          if (isJunk(l) || /^\$/.test(l)) continue;
          let name = l, price = '';
          const pm = l.match(/^(.+?)\s*[·\-—]?\s*(\$[\d.,]+|\d+[.,]\d{2})\s*$/);
          if (pm) { name = pm[1].trim(); price = pm[2].trim(); }
          if (name.length < 2 || name.length > 60) continue;
          menu.push(price ? { name, price } : { name });
        }
      }

      // Reseñas: nombre → metadata (Local Guide · N reseñas · M fotos) → fecha → texto largo.
      const testimonials = [];
      for (let i = 0; i < lines.length && testimonials.length < 3; i++) {
        if (!REVIEWER_META.test(lines[i])) continue;
        let name = '';
        for (let k = i - 1; k >= 0; k--) {
          const p = lines[k].trim();
          if (!p) continue;
          if (!isJunk(p) && !ANYMETA.test(p) && !DATE.test(p) && p.length <= 45 &&
              p.split(/\s+/).length <= 6 && !/^\$|\d{3,}/.test(p)) name = p;
          break;
        }
        let quote = '';
        for (let j = i + 1; j < lines.length; j++) {
          const q = lines[j].trim();
          if (!q) continue;
          if (ANYMETA.test(q) || DATE.test(q) || /^see translation/i.test(q) || /^[★☆*\d.\s]+$/.test(q) || isJunk(q)) continue;
          quote = q; break;
        }
        quote = quote
          .replace(/\s*(…|\.\.\.)\s*more\s*$/i, '')
          .replace(/\s*\bmore\s*$/i, '')
          .replace(/\s*see translation.*$/i, '')
          .replace(/\s*\b(like|share)\s*$/i, '')
          .trim();
        if (name && quote.length >= 40) testimonials.push({ who: name, quote });
      }

      // Solo informativo (todavía no hay dónde guardarlos de forma segura): no se envían.
      let rating = '';
      for (const l of lines) { if (/^[0-5](\.\d)?$/.test(l.trim())) { rating = l.trim(); break; } }
      let reviewCount = '';
      const rc = text.match(/\(?\b(\d[\d.,]*)\)?\s*reviews?\b/i) || text.match(/\((\d[\d.,]*)\)/);
      if (rc) reviewCount = rc[1].replace(/[.,]/g, '');
      let priceRange = '';
      const pr = text.match(/\$[\d.,]+\s*[–-]\s*\$?[\d.,]+/);
      if (pr) priceRange = pr[0].trim();
      let hours = '';
      for (const l of lines) { if (/\b(open|opens|close[sd]|abre|cierra)\b/i.test(l) && /\d/.test(l)) { hours = l.trim(); break; } }

      return { address, phone, menu, testimonials, hours, rating, reviewCount, priceRange };
    }

    // ── Guard (mismo patrón que step-3-patterns/step-4) ────────────────────
    const data = JSON.parse(localStorage.getItem(KEY) || '{}');
    if (!data.name || !data.niche) {
      window.location.href = '/onboarding/step-1';
    } else {
      let photos = [];
      try { photos = JSON.parse(localStorage.getItem(PKEY) || '[]'); } catch { photos = []; }
      if (!photos.length) {
        window.location.href = '/onboarding/step-2';
      } else {
        document.getElementById('summary-niche').textContent = data.nicheLabel || data.niche;
        document.getElementById('summary-name').textContent = data.name;
        document.getElementById('summary-photos').textContent = String(photos.length);
        if (data.prompt) form.detailedPrompt.value = data.prompt;
        if (Array.isArray(data.selectedFeatures)) {
          for (const cb of form.querySelectorAll('input[name="feature"]')) {
            cb.checked = data.selectedFeatures.includes(cb.value);
          }
        }

        if (data.whatsapp) form.whatsapp.value = data.whatsapp;
        if (data.address) form.address.value = data.address;
        if (Array.isArray(data.menu)) {
          const rows = form.querySelectorAll('.s3r-menu-row');
          data.menu.slice(0, rows.length).forEach((it, i) => {
            if (!it) return;
            rows[i].querySelector('[data-menu-name]').value = it.name || '';
            rows[i].querySelector('[data-menu-price]').value = it.price || '';
          });
        }
        if (Array.isArray(data.testimonials)) {
          const rows = form.querySelectorAll('.s3r-testi-row');
          data.testimonials.slice(0, rows.length).forEach((t, i) => {
            if (!t) return;
            rows[i].querySelector('[data-testi-quote]').value = t.quote || '';
            rows[i].querySelector('[data-testi-who]').value = t.who || '';
          });
        }

        // ── Botón "Detectar datos": llena SOLO campos vacíos, nunca pisa lo del usuario ──
        const pasteEl = document.getElementById('rd-paste');
        const detectBtn = document.getElementById('rd-detect');
        const statusEl = document.getElementById('rd-detect-status');
        const detectedEl = document.getElementById('rd-detected');
        const esc = (s) => String(s).replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));

        function renderDetected(info, notes) {
          const infoOnly = [];
          if (info.hours) infoOnly.push('Horarios: ' + info.hours);
          if (info.rating) infoOnly.push('Rating: ' + info.rating);
          if (info.reviewCount) infoOnly.push('Reseñas (total): ' + info.reviewCount);
          if (info.priceRange) infoOnly.push('Rango de precio: ' + info.priceRange);
          detectedEl.hidden = false;
          detectedEl.innerHTML =
            '<p class="s3r-detected__title">Detectado</p>' +
            '<ul class="s3r-detected__list">' +
              '<li>Dirección: ' + (info.address ? esc(info.address) : '—') + '</li>' +
              '<li>Teléfono: ' + (info.phone ? esc(info.phone) : 'no detectado (queda vacío)') + '</li>' +
              '<li>Menú: ' + (info.menu.length ? info.menu.map((m) => esc(m.name)).join(', ') : '—') + '</li>' +
              '<li>Reseñas: ' + (info.testimonials.length ? info.testimonials.map((t) => esc(t.who)).join(', ') : '—') + '</li>' +
            '</ul>' +
            (infoOnly.length ? '<p class="s3r-detected__note">Solo informativo (no se guarda todavía): ' + esc(infoOnly.join(' · ')) + '</p>' : '') +
            (notes.length ? '<p class="s3r-detected__note">⚠ ' + esc(notes.join(' · ')) + '</p>' : '');
        }

        detectBtn.addEventListener('click', () => {
          const txt = pasteEl.value || '';
          if (!txt.trim()) { statusEl.textContent = 'Pegá algo de texto primero.'; return; }
          const info = detectInfo(txt);
          const applied = [], notes = [];

          if (info.address) {
            if (!form.address.value.trim()) { form.address.value = info.address; applied.push('dirección'); }
            else if (form.address.value.trim() !== info.address) notes.push('dirección detectada, no aplicada (ya tenías una)');
          }
          if (info.phone) {
            if (!form.whatsapp.value.trim()) { form.whatsapp.value = info.phone; applied.push('teléfono'); }
            else notes.push('teléfono detectado, no aplicado (ya tenías uno)');
          }
          if (info.menu.length) {
            const rows = Array.from(form.querySelectorAll('.s3r-menu-row'));
            let used = 0, skipped = 0;
            for (const item of info.menu) {
              const row = rows.find((r) => !r.querySelector('[data-menu-name]').value.trim());
              if (!row) { skipped++; continue; }
              row.querySelector('[data-menu-name]').value = item.name;
              if (item.price) row.querySelector('[data-menu-price]').value = item.price;
              used++;
            }
            if (used) applied.push(used + ' ítem(s) de menú');
            if (skipped) notes.push(skipped + ' ítem(s) de menú sin fila libre');
          }
          if (info.testimonials.length) {
            const rows = Array.from(form.querySelectorAll('.s3r-testi-row'));
            let used = 0, skipped = 0;
            for (const t of info.testimonials) {
              const row = rows.find((r) => !r.querySelector('[data-testi-quote]').value.trim());
              if (!row) { skipped++; continue; }
              row.querySelector('[data-testi-quote]').value = t.quote;
              if (t.who) row.querySelector('[data-testi-who]').value = t.who;
              used++;
            }
            if (used) applied.push(used + ' reseña(s)');
            if (skipped) notes.push(skipped + ' reseña(s) sin fila libre');
          }

          statusEl.textContent = applied.length ? ('Aplicado: ' + applied.join(', ') + '.') : 'No detectamos datos nuevos para aplicar.';
          renderDetected(info, notes);
        });

        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const selectedFeatures = Array.from(form.querySelectorAll('input[name="feature"]:checked')).map((el) => el.value);
          const detailedPrompt = form.detailedPrompt.value.trim();
          const menu = Array.from(form.querySelectorAll('.s3r-menu-row'))
            .map((row) => ({
              name: row.querySelector('[data-menu-name]').value.trim(),
              price: row.querySelector('[data-menu-price]').value.trim(),
            }))
            .filter((it) => it.name)
            .map((it) => (it.price ? { name: it.name, price: it.price } : { name: it.name }));
          const testimonials = Array.from(form.querySelectorAll('.s3r-testi-row'))
            .map((row) => ({
              quote: row.querySelector('[data-testi-quote]').value.trim(),
              who: row.querySelector('[data-testi-who]').value.trim(),
            }))
            .filter((t) => t.quote)
            .map((t) => (t.who ? { quote: t.quote, who: t.who } : { quote: t.quote }));
          const updated = {
            ...data,
            // El prompt detallado de esta pantalla reemplaza al corto de step-1 si el usuario
            // escribió algo acá; si no, se conserva el que ya había.
            prompt: detailedPrompt || data.prompt || '',
            selectedFeatures,
            whatsapp: form.whatsapp.value.trim(),
            address: form.address.value.trim(),
            menu,
            testimonials,
          };
          localStorage.setItem(KEY, JSON.stringify(updated));
          window.location.href = '/onboarding/step-3-patterns';
        });
      }
    }
  </script>
</Onboarding>
