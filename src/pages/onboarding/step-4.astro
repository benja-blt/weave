---
// src/pages/onboarding/step-4.astro — Paso 4: el momento del WOW. Llama a /api/generate con
// los datos + patrón elegido en step-3, muestra un preview en vivo (iframe srcdoc) del HTML
// auto-contenido que devuelve generator.js, y lo deja descargar en 1 click.
// Mismo patrón de 3 estados que step-3 (loading/resultados/error), sin heading fijo en el layout.
import Onboarding from '../../layouts/Onboarding.astro';
---
<Onboarding step={4} title="Weave — Tu web está lista">
  <div class="s4">
    <!-- ── ESTADO A — LOADING ─────────────────────────────────────────────── -->
    <section id="state-loading" class="s4-loading">
      <div class="s4-loading__orb" aria-hidden="true"></div>
      <div class="s4-loading__spinner" aria-hidden="true">
        <span></span><span></span><span></span><span></span>
      </div>
      <p class="s4-loading__text">Generando tu web...</p>
      <p class="s4-loading__sub">Armando el HTML final con tu paleta y tu contenido</p>
    </section>

    <!-- ── ESTADO B — RESULTADO ───────────────────────────────────────────── -->
    <section id="state-results" class="s4-results" hidden>
      <header class="s4-results__head">
        <p class="eyebrow">Tu web está lista</p>
        <h2 class="s4-results__title">Lista para <em>publicar.</em></h2>
        <p class="s4-results__sub" id="results-sub">Vista previa en vivo — descargala y subila a cualquier hosting.</p>
      </header>

      <div class="s4-preview">
        <div class="s4-preview__bar">
          <span class="s4-preview__dot" style="background:#FF5F57"></span>
          <span class="s4-preview__dot" style="background:#FFBD2E"></span>
          <span class="s4-preview__dot" style="background:#28CA41"></span>
          <span class="s4-preview__url" id="preview-filename">weave — tu-web</span>
        </div>
        <iframe id="preview-frame" class="s4-preview__frame" title="Vista previa de tu web" sandbox="allow-scripts"></iframe>
      </div>

      <div class="s4-actions">
        <button class="btn btn--accent btn--lg" id="download-btn">Descargar HTML <span aria-hidden="true">↓</span></button>
        <a class="btn btn--ghost btn--lg" href="/onboarding/step-3">← Elegir otro patrón</a>
      </div>
      <p class="s4-meta" id="results-meta"></p>
    </section>

    <!-- ── ESTADO C — ERROR ───────────────────────────────────────────────── -->
    <section id="state-error" class="s4-error" hidden>
      <svg class="s4-error__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10" />
        <path d="M15 9l-6 6M9 9l6 6" />
      </svg>
      <h2 class="s4-error__title">Algo salió mal</h2>
      <p class="s4-error__sub" id="error-message">No pudimos generar tu web. Podés reintentar.</p>
      <div class="s4-error__actions">
        <button class="btn btn--accent btn--lg" id="retry-btn">Reintentar</button>
        <a class="btn btn--ghost btn--lg" href="/onboarding/step-3">Volver</a>
      </div>
    </section>
  </div>

  <style is:global>
    .s4 { width: 100vw; position: relative; left: 50%; margin-left: -50vw; }
    .s4-loading[hidden], .s4-results[hidden], .s4-error[hidden] { display: none; }

    /* ── Estado A: loading ─────────────────────────────────────────────────── */
    .s4-loading {
      position: relative; max-width: 560px; margin: 0 auto; padding: var(--space-16) var(--space-6) var(--space-20);
      display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--space-6);
      min-height: 50vh; justify-content: center; overflow: hidden;
    }
    .s4-loading__orb {
      position: absolute; top: 30%; left: 50%; width: min(800px, 140vw); height: 600px;
      transform: translate(-50%, -50%);
      background: radial-gradient(closest-side, rgba(6, 1, 71, 0.9), transparent);
      filter: blur(140px); z-index: 0; pointer-events: none;
      animation: s4orbpulse 2.5s ease-in-out infinite;
    }
    @keyframes s4orbpulse {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.4; }
      50% { transform: translate(-50%, -50%) scale(1.15); opacity: 0.7; }
    }
    .s4-loading__spinner { position: relative; z-index: 1; width: 54px; height: 54px; }
    .s4-loading__spinner span {
      position: absolute; width: 10px; height: 10px; border-radius: 50%;
      background: var(--accent); box-shadow: 0 0 10px var(--glow);
      animation: s4dot 1s ease-in-out infinite;
    }
    .s4-loading__spinner span:nth-child(1) { top: 0; left: 22px; animation-delay: 0ms; }
    .s4-loading__spinner span:nth-child(2) { top: 22px; right: 0; animation-delay: 250ms; }
    .s4-loading__spinner span:nth-child(3) { bottom: 0; left: 22px; animation-delay: 500ms; }
    .s4-loading__spinner span:nth-child(4) { top: 22px; left: 0; animation-delay: 750ms; }
    @keyframes s4dot { 0%, 100% { transform: scale(1); opacity: 0.3; } 50% { transform: scale(1.4); opacity: 1; } }
    .s4-loading__text { position: relative; z-index: 1; margin: 0; font-family: var(--font-family-display); font-style: italic; color: var(--ink); font-size: clamp(1.6rem, 2.8vw, 2.2rem); }
    .s4-loading__sub { position: relative; z-index: 1; margin: 0; font-size: var(--size-sm); color: var(--muted); }

    /* ── Estado B: resultado ───────────────────────────────────────────────── */
    .s4-results { max-width: 1100px; margin: 0 auto; padding: var(--space-8) var(--space-6) var(--space-20); }
    .s4-results.is-in { animation: s4fadeup 600ms var(--motion-ease-emphasized) both; }
    @keyframes s4fadeup { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .s4-results__head { max-width: 56ch; margin: 0 auto var(--space-10); text-align: center; }
    .s4-results .eyebrow { margin: 0 0 var(--space-4); font-family: var(--font-family-mono); font-size: var(--size-xs); text-transform: uppercase; letter-spacing: var(--tracking-widest); color: var(--accent); }
    .s4-results__title { margin: 0; font-family: var(--font-family-display); font-weight: var(--weight-bold); line-height: 1.15; font-size: clamp(2rem, 4vw, 3rem); color: var(--ink); }
    .s4-results__title em { font-style: italic; color: var(--accent); }
    .s4-results__sub { margin: var(--space-4) 0 0; font-size: var(--size-base); color: var(--muted); }

    .s4-preview {
      max-width: 960px; margin: 0 auto; border: 1px solid var(--line); border-radius: 16px;
      overflow: hidden; background: var(--surface); box-shadow: 0 30px 90px rgba(79, 142, 247, 0.12);
    }
    .s4-preview__bar { display: flex; align-items: center; gap: var(--space-2); padding: var(--space-3) var(--space-4); background: rgba(255, 255, 255, 0.03); border-bottom: 1px solid var(--line); }
    .s4-preview__dot { width: 12px; height: 12px; border-radius: 50%; background: rgba(255, 255, 255, 0.18); }
    .s4-preview__url { margin-left: var(--space-4); font-family: var(--font-family-mono); font-size: var(--size-xs); color: var(--muted); }
    .s4-preview__frame { display: block; width: 100%; height: 70vh; border: 0; background: #000; }

    .s4-actions { display: flex; justify-content: center; gap: var(--space-4); flex-wrap: wrap; margin-top: var(--space-10); }
    .s4-meta { margin: var(--space-5) 0 0; text-align: center; font-family: var(--font-family-mono); font-size: var(--size-xs); color: var(--muted); }

    /* ── Estado C: error ───────────────────────────────────────────────────── */
    .s4-error {
      max-width: 480px; margin: 0 auto; padding: var(--space-20) var(--space-6);
      display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--space-4);
    }
    .s4-error__icon { width: 56px; height: 56px; color: #FF4F4F; }
    .s4-error__title { margin: 0; font-family: var(--font-family-display); font-weight: var(--weight-semibold); font-size: var(--size-2xl); color: var(--ink); }
    .s4-error__sub { margin: 0; font-size: var(--size-base); color: var(--muted); }
    .s4-error__actions { display: flex; gap: var(--space-4); margin-top: var(--space-4); flex-wrap: wrap; justify-content: center; }

    @media (max-width: 720px) {
      .s4-preview__frame { height: 55vh; }
    }
    @media (prefers-reduced-motion: reduce) {
      .s4-loading__orb, .s4-loading__spinner span, .s4-results.is-in { animation: none; opacity: 1; }
    }
  </style>

  <script>
    const KEY = 'weave:onboarding';
    const PKEY = 'weave:onboarding:photos';

    const stateLoading = document.getElementById('state-loading');
    const stateResults = document.getElementById('state-results');
    const stateError = document.getElementById('state-error');
    const previewFrame = document.getElementById('preview-frame');
    const previewFilename = document.getElementById('preview-filename');
    const downloadBtn = document.getElementById('download-btn');
    const resultsMeta = document.getElementById('results-meta');
    const errorMessage = document.getElementById('error-message');
    const retryBtn = document.getElementById('retry-btn');

    let data = {};
    let photos = [];
    let generated = null; // { html, filename, size, meta }

    function showState(el) {
      for (const s of [stateLoading, stateResults, stateError]) s.hidden = s !== el;
      if (el === stateResults) {
        el.classList.remove('is-in');
        void el.offsetWidth;
        el.classList.add('is-in');
      }
    }

    downloadBtn.addEventListener('click', () => {
      if (!generated) return;
      const blob = new Blob([generated.html], { type: 'text/html' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = generated.filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    });

    async function runGeneration() {
      showState(stateLoading);
      const minDelay = new Promise((r) => setTimeout(r, 900));

      try {
        const [res] = await Promise.all([
          fetch('/api/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              business: {
                name: data.name,
                description: data.description,
                niche: data.niche,
                instagram: data.instagram,
                mood: data.mood,
                photos: photos.map((p) => p.src),
                prompt: data.prompt || '',
              },
              patternId: data.patternId,
              analysis: data.analysis,
              colors: data.colors,
              colorMode: data.colorMode || 'auto',
            }),
          }),
          minDelay,
        ]);
        const result = await res.json().catch(() => ({}));
        if (!res.ok) {
          throw new Error(result.message || result.error || `Error ${res.status}`);
        }

        generated = result;
        previewFrame.srcdoc = result.html;
        previewFilename.textContent = `weave — ${data.name}`;
        resultsMeta.textContent = `Basado en el patrón "${result.meta.pattern}" · arquetipo "${result.meta.archetype}" · ${result.size}`;
        showState(stateResults);
      } catch (err) {
        errorMessage.textContent = err.message || 'No pudimos generar tu web. Podés reintentar.';
        showState(stateError);
      }
    }

    // ── Guard ─────────────────────────────────────────────────────────────
    data = JSON.parse(localStorage.getItem(KEY) || '{}');
    if (!data.name || !data.niche) {
      window.location.href = '/onboarding/step-1';
    } else if (!data.patternId) {
      window.location.href = '/onboarding/step-3';
    } else {
      try { photos = JSON.parse(localStorage.getItem(PKEY) || '[]'); } catch { photos = []; }
      retryBtn.addEventListener('click', runGeneration);
      runGeneration();
    }
  </script>
</Onboarding>
