{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plg.local/components/footer/footer.schema.json",
  "title": "Footer content",
  "description": "Valida el `content` de una sección type=footer. contentRequired: links (columnas de navegación).",
  "type": "object",
  "additionalProperties": false,
  "required": ["links"],
  "properties": {
    "logo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string" },
        "href": { "type": "string", "default": "#" }
      }
    },
    "tagline": { "type": "string" },
    "links": {
      "type": "array",
      "minItems": 1,
      "description": "Columnas de navegación.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["items"],
        "properties": {
          "title": { "type": "string" },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "href"],
              "properties": {
                "label": { "type": "string" },
                "href": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "social": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "href"],
        "properties": {
          "label": { "type": "string" },
          "href": { "type": "string" }
        }
      }
    },
    "copyright": { "type": "string" }
  }
}
