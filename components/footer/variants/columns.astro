---
// components/footer/variants/columns.astro — variant DEFAULT.
// Marca + columnas de navegación + barra inferior legal/social. HTML semántico.
const { id, content, motion } = Astro.props;
const motionName = motion?.override ?? motion?.profile ?? 'minimal';
const { logo, tagline, links = [], social = [], copyright } = content;
---
<footer id={id} class="plg-footer plg-footer--columns" data-motion={motionName} data-motion-el="footer">
  <div class="plg-footer__inner">
    <div class="plg-footer__top">
      <div class="plg-footer__brand">
        {logo && <a class="plg-footer__logo" href={logo.href ?? '#'}>{logo.text}</a>}
        {tagline && <p class="plg-footer__tagline">{tagline}</p>}
      </div>
      {links.map((col: any) => (
        <nav class="plg-footer__col" aria-label={col.title}>
          {col.title && <h3>{col.title}</h3>}
          <ul>
            {col.items.map((l: any) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    <div class="plg-footer__bottom">
      {copyright && <p class="plg-footer__copy">{copyright}</p>}
      {social.length > 0 && (
        <ul class="plg-footer__social" role="list">
          {social.map((s: any) => (
            <li><a href={s.href}>{s.label}</a></li>
          ))}
        </ul>
      )}
    </div>
  </div>
</footer>
