---
// components/navbar/variants/solid.astro — variant DEFAULT.
// Barra sólida, sticky. Menú mobile = disclosure nativo <details>/<summary>:
//   A11y (funciona SIN JS):
//     - <summary> es un control real: recibe foco y abre/cierra con Enter/Espacio.
//     - Estado expanded/collapsed lo expone el navegador a lectores de pantalla.
//     - Menú cerrado → los links están display:none → NO son tabbables.
//   Enhancement progresivo (script vanilla, sin libs — el base anda sin él):
//     - Escape cierra y devuelve el foco al <summary>.
//     - Cerrar al elegir un link / al clickear afuera.
// El CTA (actions) vive FUERA del <details> → SIEMPRE visible y accesible en mobile.
const { id, content, motion } = Astro.props;
const motionName = motion?.override ?? motion?.profile ?? 'minimal';
const { logo, links = [], actions = [] } = content;
const menuId = `${id}-menu`;
---
<header id={id} class="plg-navbar plg-navbar--solid" data-motion={motionName} data-motion-el="navbar">
  <nav class="plg-navbar__inner" aria-label="Principal">
    <a class="plg-navbar__logo" href={logo.href ?? '#'} data-motion-el="logo">
      {logo.src
        ? <img src={logo.src} alt={logo.alt ?? logo.text ?? 'Logo'} height="28" width="auto" />
        : <span>{logo.text}</span>}
    </a>

    <details class="plg-navbar__disclosure">
      <summary class="plg-navbar__burger" aria-label="Menú" aria-controls={menuId}>
        <span></span><span></span><span></span>
      </summary>
    </details>

    <ul class="plg-navbar__links" id={menuId}>
      {links.map((l: any) => (
        <li>
          <a href={l.href} aria-current={l.current ? 'page' : undefined}>{l.label}</a>
        </li>
      ))}
    </ul>

    {actions.length > 0 && (
      <div class="plg-navbar__actions">
        {actions.map((a: any) => (
          <a class={`plg-btn plg-btn--${a.variant ?? 'primary'}`} href={a.href}>{a.label}</a>
        ))}
      </div>
    )}
  </nav>
</header>

<script>
  // Enhancement progresivo (a11y). El abrir/cerrar base funciona SIN este script (native <details>).
  (() => {
    const close = (d, focusSummary) => {
      d.open = false;
      if (focusSummary) d.querySelector('summary')?.focus();
    };
    // Escape: cierra el menú abierto y devuelve el foco al disparador.
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      document.querySelectorAll('details.plg-navbar__disclosure[open]').forEach((d) => close(d, true));
    });
    document.querySelectorAll('details.plg-navbar__disclosure').forEach((d) => {
      const menuId = d.querySelector('summary')?.getAttribute('aria-controls');
      const menu = menuId ? document.getElementById(menuId) : null;
      // Cerrar al elegir un link.
      menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => close(d, false)));
      // Cerrar al clickear afuera.
      document.addEventListener('click', (e) => {
        if (d.open && !d.contains(e.target) && !(menu && menu.contains(e.target))) close(d, false);
      });
    });
  })();
</script>
