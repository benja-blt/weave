---
// components/cta/variants/fullbleed.astro
// Variant `fullbleed`: bloque de borde a borde con fondo visual.
//   - CON media.image: la imagen es el fondo + scrim (color-mix sobre token) para contraste.
//   - SIN imagen: degrada a fondo accent (como el banner) → nunca queda roto.
//   - Texto en --color-accent-fg y botones on-accent/ghost-invert (los mismos del banner):
//     legibles tanto sobre accent como sobre imagen+scrim.
//   - video-bg = enhancement de L4: si el content trae media.video expongo el contrato
//     data-enhance (kind + src + fallback). El loader (assets/loaders/video.js, Wave B) lo
//     monta encima; acá el base sigue mostrando imagen/accent (fallback siempre renderizado).
const { id, content, motion } = Astro.props;
const motionName = motion?.override ?? motion?.profile ?? 'minimal';
const { eyebrow, headline, subhead, action, secondary, media } = content;
const img = media?.image;
const enhanceKind = media?.video ? 'video-bg' : undefined;
---
<section
  id={id}
  class="plg-cta plg-cta--fullbleed"
  data-cta-has-media={img ? 'true' : 'false'}
  data-enhance={enhanceKind}
  data-enhance-src={enhanceKind ? media.video : undefined}
  data-enhance-fallback={enhanceKind ? (img ? 'poster' : 'static') : undefined}
  data-motion={motionName}
  data-motion-el="cta"
>
  {img && (
    <img
      class="plg-cta__bg"
      src={img}
      alt={media.alt ?? ''}
      width={media.width}
      height={media.height}
      loading="lazy"
      decoding="async"
      data-motion-el="media"
    />
  )}
  <div class="plg-cta__inner plg-cta__inner--fullbleed">
    <div class="plg-cta__text">
      {eyebrow && <p class="plg-cta__eyebrow" data-motion-el="eyebrow">{eyebrow}</p>}
      <h2 class="plg-cta__headline" data-motion-el="headline">{headline}</h2>
      {subhead && <p class="plg-cta__subhead" data-motion-el="subhead">{subhead}</p>}
    </div>
    <div class="plg-cta__actions" data-motion-el="actions">
      <a class="plg-btn plg-btn--on-accent" href={action.href}>{action.label}</a>
      {secondary && (
        <a class="plg-btn plg-btn--ghost-invert" href={secondary.href}>{secondary.label}</a>
      )}
    </div>
  </div>
</section>
