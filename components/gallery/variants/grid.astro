---
// components/gallery/variants/grid.astro — variant DEFAULT.
// Grilla responsive. Fallback-first: renderiza imágenes; video (mixed-media) es enhancement futuro.
const { id, content, motion } = Astro.props;
const motionName = motion?.override ?? motion?.profile ?? 'minimal';
const { eyebrow, title, intro, items = [] } = content;
---
<section id={id} class="plg-gallery plg-gallery--grid" data-motion={motionName} data-motion-el="gallery">
  <div class="plg-gallery__inner">
    {(eyebrow || title || intro) && (
      <header class="plg-gallery__header">
        {eyebrow && <p class="plg-gallery__eyebrow" data-motion-el="eyebrow">{eyebrow}</p>}
        {title && <h2 class="plg-gallery__title" data-motion-el="title">{title}</h2>}
        {intro && <p class="plg-gallery__intro" data-motion-el="intro">{intro}</p>}
      </header>
    )}
    <ul class="plg-gallery__grid" role="list">
      {items.map((it: any, i: number) => (
        <li class="plg-gallery__item">
          <figure class="plg-gallery__figure" data-motion-el="item" data-motion-order={i}>
            <img
              src={it.src}
              alt={it.alt}
              width={it.width}
              height={it.height}
              loading="lazy"
              decoding="async"
            />
            {it.caption && <figcaption class="plg-gallery__caption">{it.caption}</figcaption>}
          </figure>
        </li>
      ))}
    </ul>
  </div>
</section>
