---
// components/gallery/index.astro
// Contrato L2: props de instancia + content (validado por gallery.schema.json).
// Variant default `grid`: grilla CSS responsive, imágenes con width/height (anti-CLS).
// El fallback (imagen) se renderiza siempre; el enhancement (video en mixed-media) solo si active.
import './gallery.css';
import Grid from './variants/grid.astro';
import Masonry from './variants/masonry.astro';
import Carousel from './variants/carousel.astro';
import FullbleedScroll from './variants/fullbleed-scroll.astro';
import MixedMedia from './variants/mixed-media.astro';

export interface GalleryItem {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  caption?: string;
  video?: string; // enhancement (mixed-media); inerte en grid default
}
export interface GalleryContent {
  eyebrow?: string;
  title?: string;
  intro?: string;
  items: GalleryItem[];
}
export interface Props {
  id?: string;
  variant?: string;
  content?: GalleryContent;
  theme?: string;
  motion?: any;
  enhancement?: any;
}

// Contenido genérico de ejemplo (NO un cliente real). Placeholders locales (svg data-uri).
const ph = (label: string) =>
  `data:image/svg+xml;utf8,` +
  encodeURIComponent(
    `<svg xmlns='http://www.w3.org/2000/svg' width='800' height='600'><rect width='100%' height='100%' fill='%23e7d7c4'/><text x='50%' y='50%' fill='%236f513a' font-family='sans-serif' font-size='40' text-anchor='middle' dominant-baseline='middle'>${label}</text></svg>`
  );
const demo: GalleryContent = {
  eyebrow: 'Galería',
  title: 'Un vistazo al trabajo',
  intro: 'Proyectos seleccionados: dirección de arte, motion y desarrollo.',
  items: [
    { src: ph('01'), alt: 'Proyecto 01', width: 800, height: 600, caption: 'Identidad de marca' },
    { src: ph('02'), alt: 'Proyecto 02', width: 800, height: 600, caption: 'Sitio editorial' },
    { src: ph('03'), alt: 'Proyecto 03', width: 800, height: 600, caption: 'Campaña de producto' },
    { src: ph('04'), alt: 'Proyecto 04', width: 800, height: 600, caption: 'Experiencia interactiva' },
    { src: ph('05'), alt: 'Proyecto 05', width: 800, height: 600, caption: 'Packaging' },
    { src: ph('06'), alt: 'Proyecto 06', width: 800, height: 600, caption: 'Dirección de arte' },
  ],
};

const {
  id = 'gallery-1',
  variant = 'grid',
  content = demo,
  motion,
  enhancement,
} = Astro.props;

const variants: Record<string, any> = {
  grid: Grid,
  masonry: Masonry,
  carousel: Carousel,
  'fullbleed-scroll': FullbleedScroll,
  'mixed-media': MixedMedia,
};
const Variant = variants[variant] ?? Grid;
---
<Variant {id} {content} {motion} {enhancement} />
